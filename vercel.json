export const config = {
  runtime: 'edge',
  maxDuration: 60
};

// ===== YOUR ORIGINAL VALUES =====
const UUID = 'b5ee5eff-0b9e-4bcf-bf3d-4a53ce15b8be';
const BACKEND = 'winter.lovolyxa.workers.dev';
// =================================

export default async function handler(request) {
  const url = new URL(request.url);
  const host = request.headers.get('host');

  // ❌ REMOVED: broken WebSocket proxy
  // Vercel will handle WS via rewrite automatically

  // ✅ Keep your VLESS format (using Vercel domain as CDN)
  const vlessUrl = `vless://${UUID}@${host}:443?path=%2Fapi%2Fv2ray&security=tls&alpn=h2%2Chttp%2F1.1&encryption=none&host=${host}&fp=chrome&type=ws&sni=${host}#Vercel-V2Ray`;

  // ✅ Your full config (restored)
  const config = {
    vless: vlessUrl,
    uuid: UUID,
    server: host,
    port: 443,
    path: "/91.227.40.125-8443",
    security: "tls",
    alpn: "h2,http/1.1",
    encryption: "none",
    type: "ws",
    sni: host,
    fingerprint: "chrome",
    allowInsecure: false,
    network: "ws",
    vercel_cdn: true,
    backend: BACKEND,
    timestamp: new Date().toISOString()
  };

  return new Response(JSON.stringify(config, null, 2), {
    status: 200,
    headers: {
      'Content-Type': 'application/json',
      'Access-Control-Allow-Origin': '*',
      'Cache-Control': 'no-cache, no-transform',
      'Server': 'vercel-edge',
      'X-Powered-By': 'Vercel'
    }
  });
}
